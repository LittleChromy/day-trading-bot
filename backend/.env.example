# Alpaca API Configuration
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # Use paper trading URL

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/day_trading_bot

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_secret_key_here

# App Configuration
LOG_LEVEL=INFO
STOCK_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,NVDA,TSLA,AMD,META,NFLX,UBER
CHECK_INTERVAL=60  # seconds between strategy checks
